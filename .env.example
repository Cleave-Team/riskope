# ============================================================
# API Keys
# ============================================================

# DART Open API 키 (https://opendart.fss.or.kr/ 에서 발급)
RISKOPE_DART_API_KEY=

# Massive.com SEC API 키 (https://massive.com/ 에서 발급)
RISKOPE_MASSIVE_API_KEY=

# Google Gemini API 키 (Stage 1 추출, Stage 3 Judge, Refiner)
RISKOPE_GEMINI_API_KEY=

# OpenAI API 키 (Stage 2 임베딩)
RISKOPE_OPENAI_API_KEY=

# ============================================================
# Database (PostgreSQL)
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=riskope
POSTGRES_PASSWORD=riskope
POSTGRES_DATABASE=riskope

# ============================================================
# S3 Storage
# ============================================================

# S3 버킷명 (DART 공시 MD 파일 저장)
RISKOPE_S3_BUCKET=riskope-filings

# S3 리전
RISKOPE_S3_REGION=ap-northeast-2

# AWS 자격증명 (빈 값이면 IAM role / instance profile 사용)
RISKOPE_S3_ACCESS_KEY=
RISKOPE_S3_SECRET_KEY=

# ============================================================
# Langfuse (LLM Observability)
# ============================================================

# Langfuse 프로젝트 키 (https://cloud.langfuse.com 에서 발급)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ============================================================
# LLM 모델 설정 (선택)
# ============================================================

# RISKOPE_EXTRACTION_MODEL=gemini-2.5-flash
# RISKOPE_JUDGE_MODEL=gemini-2.5-flash
# RISKOPE_EMBEDDING_MODEL=text-embedding-3-small   (OpenAI)
# RISKOPE_EMBEDDING_DIMENSIONS=1536
# RISKOPE_JUDGE_THRESHOLD=4
